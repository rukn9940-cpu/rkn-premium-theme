{
  "name": "rkn-premium-theme",
  "version": "1.0.0",
  "description": "RKN Premium Theme — a commercial Salla Twilight theme for the Salla Theme Store. Premium storefront, design system, and merchant-configurable shopping features.",
  "license": "UNLICENSED",
  "private": true,
  "author": "RUKN",
  "repository": {
    "type": "git",
    "url": "https://github.com/rukn9940-cpu/rkn-premium-theme.git"
  },
  "homepage": "https://github.com/rukn9940-cpu/rkn-premium-theme",
  "bugs": {
    "url": "https://github.com/rukn9940-cpu/rkn-premium-theme/issues"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "development": "webpack --mode development",
    "dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "production": "webpack --mode production",
    "build": "webpack --mode production",
    "lint:js": "eslint \"src/assets/js/**/*.js\"",
    "lint:js:fix": "eslint \"src/assets/js/**/*.js\" --fix",
    "lint:css": "stylelint \"src/assets/styles/**/*.scss\"",
    "lint:css:fix": "stylelint \"src/assets/styles/**/*.scss\" --fix",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "format": "prettier --write \"src/assets/js/**/*.js\" \"src/assets/styles/**/*.scss\"",
    "twilight:preview": "salla theme preview",
    "twilight:serve": "salla theme serve"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@salla.sa/twilight": "^2.14.475",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.11.0",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "eslint": "^8.57.0",
    "mini-css-extract-plugin": "^2.10.0",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.0",
    "postcss-preset-env": "^9.6.0",
    "prettier": "^3.4.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.6",
    "stylelint": "^16.10.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "terser-webpack-plugin": "^5.3.10",
    "webpack": "^5.107.1",
    "webpack-cli": "^5.1.4"
  }
}
