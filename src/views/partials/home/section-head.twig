{#
    Reusable homepage section header
    ================================
    Include with:
        {% include 'partials.home.section-head' with {
            title: '...',
            subtitle: '...'|default(null),
            eyebrow: '...'|default(null),
            link_url: '...'|default(null),
            link_label: '...'|default(null)
        } %}
#}
<div class="rkn-section-head" data-reveal>
    <div class="rkn-section-head__main">
        {% if eyebrow %}
            <span class="rkn-section-head__eyebrow">{{ eyebrow }}</span>
        {% endif %}
        <h2 class="rkn-section-head__title">{{ title }}</h2>
        {% if subtitle %}
            <p class="rkn-section-head__subtitle">{{ subtitle }}</p>
        {% endif %}
    </div>
    {% if link_url and link_label %}
        <a href="{{ link_url }}" class="rkn-section-head__link">
            {{ link_label }}
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
        </a>
    {% endif %}
</div>
