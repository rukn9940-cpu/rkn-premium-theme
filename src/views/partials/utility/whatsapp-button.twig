{#
    Floating WhatsApp button
    =========================
    Plain `https://wa.me/` deep link (no Salla API involved) — gated by the
    `whatsapp_enabled` + `whatsapp_number` theme settings.

    | whatsapp_number | string | digits only, with country code, no leading + or 0 |
#}
{% set whatsapp_number = theme.settings.get('whatsapp_number')|default('')|replace({'+': '', ' ': '', '-': ''}) %}

{% if theme.settings.get('whatsapp_enabled', false) and whatsapp_number %}
    <a
        href="https://wa.me/{{ whatsapp_number }}"
        class="whatsapp-button"
        target="_blank"
        rel="noopener"
        aria-label="{{ trans('common.elements.whatsapp_us') }}"
    >
        <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.5c-5.25 0-9.5 4.25-9.5 9.5 0 1.7.45 3.3 1.24 4.68L2.5 21.5l4.98-1.3A9.44 9.44 0 0 0 12 21.5c5.25 0 9.5-4.25 9.5-9.5s-4.25-9.5-9.5-9.5Zm0 17.2c-1.53 0-2.96-.42-4.18-1.15l-.3-.18-2.95.77.79-2.88-.2-.3A7.68 7.68 0 0 1 4.3 12c0-4.25 3.45-7.7 7.7-7.7s7.7 3.45 7.7 7.7-3.45 7.7-7.7 7.7Zm4.22-5.77c-.23-.12-1.36-.67-1.57-.75-.21-.08-.36-.12-.51.12-.15.23-.59.75-.72.9-.13.15-.27.17-.5.06-.23-.12-.96-.35-1.83-1.13-.68-.6-1.13-1.35-1.27-1.58-.13-.23-.01-.35.1-.47.11-.11.23-.27.35-.4.12-.14.15-.23.23-.39.08-.15.04-.29-.02-.4-.06-.12-.51-1.22-.7-1.68-.18-.44-.37-.38-.51-.39h-.44c-.15 0-.4.06-.6.29-.21.23-.79.77-.79 1.87 0 1.1.81 2.16.92 2.31.12.15 1.6 2.45 3.89 3.43.54.24.97.38 1.3.48.55.17 1.04.15 1.44.09.44-.07 1.36-.55 1.55-1.09.19-.53.19-.99.13-1.09-.06-.09-.21-.15-.44-.27Z" />
        </svg>
        <span class="sr-only">{{ trans('common.elements.whatsapp_us') }}</span>
    </a>
{% endif %}
