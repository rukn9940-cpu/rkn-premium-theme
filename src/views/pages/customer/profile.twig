{#
    Customer Profile Page
    ======================
    | user.first_name/.last_name/.email/.mobile/.birthday/.gender  | see docs.salla.dev — Customer Profile Page |
    | user.is_notifiable                                            | bool                                        |
#}
{% extends "layouts.customer" %}

{% block title %}{{ trans('pages.account.profile') }} | {{ store.name }}{% endblock %}

{% block account_content %}
    <div class="account-card">
        <h1 class="account-card__title">{{ trans('pages.account.profile') }}</h1>

        {% hook 'customer:profile.form.start' %}

        <form class="profile-form" onsubmit="return salla.form.onSubmit('profile.update', event)">
            {% hook 'customer:profile.form.fields.start' %}

            <div class="profile-form__grid">
                <div class="form-field">
                    <label for="first-name">{{ trans('pages.profile.first_name') }}</label>
                    <input type="text" name="first_name" id="first-name" value="{{ user.first_name }}" required>
                </div>

                <div class="form-field">
                    <label for="last-name">{{ trans('pages.profile.last_name') }}</label>
                    <input type="text" name="last_name" id="last-name" value="{{ user.last_name }}" required>
                </div>

                <div class="form-field">
                    <label for="email">{{ trans('common.elements.email') }}</label>
                    <input type="email" name="email" id="email" value="{{ user.email }}" required>
                </div>

                <div class="form-field">
                    <label for="mobile">{{ trans('common.elements.mobile') }}</label>
                    <input type="tel" name="mobile" id="mobile" value="{{ user.mobile }}">
                </div>

                <div class="form-field">
                    <label for="birthday">{{ trans('pages.profile.birthday') }}</label>
                    <input type="text" name="birthday" id="birthday" value="{{ user.birthday }}" placeholder="{{ trans('pages.profile.birthday_placeholder') }}">
                </div>

                <div class="form-field">
                    <label for="gender">{{ trans('pages.profile.gender') }}</label>
                    <select name="gender" id="gender">
                        <option value="">{{ trans('pages.profile.gender_placeholder') }}</option>
                        <option value="male" {{ user.gender == 'male' ? 'selected' : '' }}>{{ trans('pages.profile.male') }}</option>
                        <option value="female" {{ user.gender == 'female' ? 'selected' : '' }}>{{ trans('pages.profile.female') }}</option>
                    </select>
                </div>
            </div>

            <label class="profile-form__checkbox">
                <input type="checkbox" name="is_notifiable" value="1" {{ user.is_notifiable ? 'checked' : '' }}>
                {{ trans('pages.profile.notifiable') }}
            </label>

            {% hook 'customer:profile.form.fields.end' %}

            {% hook 'customer:profile.form.submit.start' %}
            <salla-button type="submit" class="profile-form__submit">
                {{ trans('common.elements.save') }}
            </salla-button>
            {% hook 'customer:profile.form.submit.end' %}
        </form>

        {% hook 'customer:profile.form.end' %}

        <salla-verify-modal></salla-verify-modal>
    </div>
{% endblock %}
