{#
    Home Page — RKN Premium Theme (Electronics / CCTV / Smart Home)
    =================================================================
    Custom homepage shell for a premium electronics storefront.
    Section order is merchant-controlled via `{% component home %}` in
    the Salla Partners Portal — recommended RKN layout:

      1. Hero Banner
      2. Store Features (trust strip — Theme Feature)
      3. Store Categories
      4. Best Sellers
      5. Promotional Banners
      6. New Arrivals
      7. Promotional Offer
      8. Brand Showcase
      9. Testimonials (Theme Feature)

    Markup lives under `components/home/` with reusable partials in
    `partials/home/`. Presentation uses the `rkn-*` design system.
#}
{% extends "layouts.master" %}

{% block title %}{{ store.name }}{% if store.tagline %} | {{ store.tagline }}{% endif %}{% endblock %}
{% block meta_description %}{{ store.description|striptags|default(store.name) }}{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ store.url }}">
{% endblock %}

{% block head_scripts %}
    {{ parent() }}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ store.name }}">
    <meta property="og:description" content="{{ store.description|striptags|default(store.name) }}">
    <meta property="og:url" content="{{ store.url }}">
    {% if store.logo %}<meta property="og:image" content="{{ store.logo }}">{% endif %}
    <meta name="twitter:card" content="summary_large_image">

    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Store",
        "name": {{ store.name|json_encode|raw }},
        "url": {{ store.url|json_encode|raw }}
        {%- if store.logo %}, "logo": {{ store.logo|json_encode|raw }}{% endif -%}
    }
    </script>
{% endblock %}

{% block content %}
    <div class="rkn-home">
        <h1 class="sr-only">{{ store.name }}{% if store.tagline %} — {{ store.tagline }}{% endif %}</h1>

        {% component home %}

        {% if theme.settings.get('recently_viewed_enabled', true) %}
            <div class="rkn-home__tail">
                {% include 'partials.utility.recently-viewed' %}
            </div>
        {% endif %}
        {% if theme.settings.get('smart_recommendations_enabled', true) %}
            <div class="rkn-home__tail">
                {% include 'partials.utility.smart-recommendations' %}
            </div>
        {% endif %}
    </div>
{% endblock %}
