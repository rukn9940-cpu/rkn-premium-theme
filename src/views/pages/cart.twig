{#
    Cart Page
    =========
    | Variable                  | Type   | Description                          |
    |-----------------------------|--------|---------------------------------------|
    | cart.items[]               | array  | id, product_name, product_image, url,  |
    |                             |        | quantity, price, total, is_available   |
    | cart.sub_total/.total       | float  |                                        |
    | cart.discount/.tax_amount   | float  |                                        |
    | cart.is_require_shipping    | bool   |                                        |

    Reference: docs.salla.dev — Cart Page Template.
#}
{% extends "layouts.master" %}

{% block title %}{{ trans('pages.cart.title') }} | {{ store.name }}{% endblock %}

{% block head_scripts %}
    {{ parent() }}
    <meta name="robots" content="noindex, nofollow">
{% endblock %}

{% block content %}
    <div class="container cart-page">
        <h1 class="cart-page__title">{{ trans('pages.cart.title') }}</h1>

        {% if cart.items is not empty %}
            <div class="cart-page__grid">
                <div class="cart-page__items">
                    {% for item in cart.items %}
                        <article class="cart-item{{ item.is_available ? '' : ' cart-item--unavailable' }}" id="item-{{ item.id }}">
                            <a href="{{ item.url }}" class="cart-item__media">
                                <img src="{{ item.product_image }}" alt="{{ item.product_name }}" loading="lazy" width="120" height="120">
                            </a>

                            <div class="cart-item__body">
                                <a href="{{ item.url }}" class="cart-item__name">{{ item.product_name }}</a>

                                {% if not item.is_available %}
                                    <span class="cart-item__unavailable-badge">{{ trans('pages.cart.unavailable') }}</span>
                                {% endif %}

                                <span class="cart-item__price">{{ item.price|money }}</span>

                                <div class="cart-item__controls">
                                    {% if not item.is_hidden_quantity %}
                                        <salla-quantity-input
                                            cart-item-id="{{ item.id }}"
                                            max="{{ item.max_quantity }}"
                                            value="{{ item.quantity }}"
                                            name="quantity"
                                        ></salla-quantity-input>
                                    {% endif %}

                                    <button
                                        type="button"
                                        class="cart-item__remove"
                                        onclick="salla.cart.removeItem({{ item.id }})"
                                    >
                                        <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                                            <path d="M4 6h12M8 6V4h4v2M6 6l1 10h6l1-10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                        {{ trans('pages.cart.remove') }}
                                    </button>
                                </div>
                            </div>

                            <span class="cart-item__total">{{ item.total|money }}</span>
                        </article>
                    {% endfor %}
                </div>

                <aside class="cart-page__summary">
                    <h2 class="cart-page__summary-title">{{ trans('pages.cart.summary') }}</h2>

                    <div class="cart-page__summary-row">
                        <span>{{ trans('pages.cart.items_total') }}</span>
                        <strong>{{ cart.sub_total|money }}</strong>
                    </div>

                    {% if cart.discount %}
                        <div class="cart-page__summary-row cart-page__summary-row--discount">
                            <span>{{ trans('pages.cart.discount') }}</span>
                            <strong>-{{ cart.discount|money }}</strong>
                        </div>
                    {% endif %}

                    {% if cart.tax_amount %}
                        <div class="cart-page__summary-row">
                            <span>{{ trans('pages.cart.tax') }}</span>
                            <strong>{{ cart.tax_amount|money }}</strong>
                        </div>
                    {% endif %}

                    {% if cart.is_require_shipping %}
                        <div class="cart-page__summary-row">
                            <span>{{ trans('pages.cart.shipping') }}</span>
                            <strong>
                                {% if cart.has_shipping %}
                                    {{ cart.real_shipping_cost|money }}
                                {% else %}
                                    {{ trans('pages.cart.shipping_calculated_at_checkout') }}
                                {% endif %}
                            </strong>
                        </div>
                    {% endif %}

                    <div class="cart-page__summary-row cart-page__summary-row--total">
                        <span>{{ trans('pages.cart.total') }}</span>
                        <strong>{{ cart.total|money }}</strong>
                    </div>

                    <a href="{{ page('checkout') }}" class="btn btn--primary btn--lg btn--block">
                        {{ trans('pages.cart.checkout') }}
                    </a>

                    <a href="{{ store.url }}" class="cart-page__continue-link">
                        {{ trans('pages.cart.continue_shopping') }}
                    </a>
                </aside>
            </div>
        {% else %}
            <div class="cart-page__empty">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M3 4h2l2.4 12.2a2 2 0 0 0 2 1.6h7.7a2 2 0 0 0 2-1.6L21 8H6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" />
                    <circle cx="9" cy="21" r="1.2" fill="currentColor" />
                    <circle cx="17" cy="21" r="1.2" fill="currentColor" />
                </svg>
                <h2>{{ trans('pages.cart.empty_title') }}</h2>
                <p>{{ trans('pages.cart.empty_text') }}</p>
                <a href="{{ store.url }}" class="btn btn--primary">{{ trans('pages.cart.continue_shopping') }}</a>
            </div>
        {% endif %}
    </div>

    {% if theme.settings.get('recently_viewed_enabled', true) %}
        {% include 'partials.utility.recently-viewed' %}
    {% endif %}
    {% if theme.settings.get('smart_recommendations_enabled', true) %}
        {% include 'partials.utility.smart-recommendations' %}
    {% endif %}
{% endblock %}
