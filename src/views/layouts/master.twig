{#
    Master Layout
    =============
    The single HTML shell every page template extends via
    `{% extends "layouts.master" %}`. It owns the document skeleton, required
    Twilight hooks, and the extension points (`block`s) that pages/components
    fill in — it does not own any visual design itself.

    Available blocks (override from a child template as needed):
      - meta_description : per-page SEO description
      - canonical         : per-page canonical <link>
      - head_scripts      : per-page <head> scripts (analytics, JSON-LD, ...)
      - styles            : per-page extra stylesheet <link> tags (call
                             {{ parent() }} first to keep app.css)
      - header            : defaults to {% component 'header.header' %}
      - content           : main page content (required in every child page)
      - footer            : defaults to {% component 'footer.footer' %}
      - scripts           : per-page end-of-body scripts (call {{ parent() }}
                             first to keep app.js)

    Reference: docs.salla.dev — Twilight Master Layout & Template Hooks.
#}
{% set dark_mode_enabled = theme.settings.get('dark_mode_enabled', true) %}
<!DOCTYPE html>
<html
    lang="{{ store.language.code|default('ar') }}"
    dir="{{ theme.is_rtl ? 'rtl' : 'ltr' }}"
    data-btn-style="{{ theme.settings.get('button_style', 'pill') }}"
    data-product-card-style="{{ theme.settings.get('product_card_style', 'standard') }}"
>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    {% if dark_mode_enabled %}
        {# Applied before first paint (no external file/await) to avoid a
           flash of the wrong theme — kept in sync at runtime by
           `js/modules/theme-mode.js`. #}
        <script>
            (function () {
                try {
                    var stored = window.localStorage.getItem('rkn-theme-mode');
                    var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                    document.documentElement.setAttribute('data-theme', stored || (prefersDark ? 'dark' : 'light'));
                } catch (e) {
                    document.documentElement.setAttribute('data-theme', 'light');
                }
            })();
        </script>
    {% endif %}

    {# Baseline SEO — per-page titles/descriptions override these blocks. #}
    <title>{% block title %}{{ store.name }}{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}{{ store.description|striptags|default('') }}{% endblock %}">
    {% block canonical %}{% endblock %}

    {# Global Open Graph fields shared by every page; per-page og:title/og:type/
       og:description/og:image are added on top of these via each page's
       `head_scripts` block. #}
    <meta property="og:site_name" content="{{ store.name }}">
    {% set og_locale_map = { 'ar': 'ar_AR', 'en': 'en_US' } %}
    <meta property="og:locale" content="{{ og_locale_map[store.language.code|default('ar')]|default(store.language.code|default('ar')) }}">

    {% if store.icon %}
        <link rel="icon" href="{{ store.icon }}">
        <link rel="apple-touch-icon" href="{{ store.icon }}">
    {% endif %}
    {#
        Theme design tokens exposed as CSS custom properties so the
        merchant's chosen brand color (Theme Settings → Color Preset, or
        Partners Portal → Theme Features → Color) reaches the compiled
        stylesheet without a rebuild. See the partial for the full priority
        rules and the 10 built-in preset palettes.
    #}
    {% include 'partials.utility.theme-color-vars' %}
    {% include 'partials.utility.rkn-brand-vars' %}
    {% include 'partials.utility.design-system-vars' %}

    {% block head_scripts %}{% endblock %}

    {# Salla-managed head injections (apps, tracking, merchant custom code). #}
    {% hook 'head:start' %}
    {% hook head %}

    <style>
        :root {
            --font-main: '{{ theme.font.name|default('inherit') }}';
        }
    </style>

    <link rel="stylesheet" href="{{ 'app.css'|asset }}">
    {% block styles %}{% endblock %}

    {% hook 'head:end' %}
</head>
<body>
    {% include 'partials.accessibility.skip-link' %}

    {% hook 'body:start' %}

    {% block header %}{% component 'header.header' %}{% endblock %}

    <main id="main-content" role="main">
        {% block content %}{% endblock %}
    </main>

    {% block footer %}{% component 'footer.footer' %}{% endblock %}

    {% if theme.settings.get('back_to_top_enabled', true) %}
        {% include 'partials.utility.back-to-top' %}
    {% endif %}
    {% include 'partials.utility.whatsapp-button' %}
    {% if theme.settings.get('quick_view_enabled', true) %}
        {% include 'partials.utility.quick-view' %}
    {% endif %}
    {% if theme.settings.get('compare_enabled', true) %}
        {% include 'partials.utility.compare-bar' %}
        {% include 'partials.utility.compare-modal' %}
    {% endif %}

    {% hook 'body:end' %}

    <script defer src="{{ 'app.js'|asset }}"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
