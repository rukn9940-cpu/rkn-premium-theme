{#
    RKN Best Sellers — top-selling products shelf
    Auto-fetches via Salla `source="sales"` or manual product picker.
#}
{% set mode = component.source_mode|default('auto') %}
{% set use_manual = mode == 'manual' and component.products is defined and component.products is not empty %}
{% set use_auto = mode == 'auto' %}

{% if use_manual or use_auto %}
    {% include 'partials.home.product-shelf' with {
        title: component.title|default(trans('home.best_sellers.default_title')),
        subtitle: component.subtitle|default(null),
        eyebrow: trans('home.best_sellers.eyebrow'),
        link_url: component.view_all_url|default(null),
        link_label: component.view_all_url ? trans('home.view_all') : null,
        products: use_manual ? component.products : [],
        source: use_auto ? 'sales' : null,
        limit: component.limit|default(8)
    } %}
{% endif %}
