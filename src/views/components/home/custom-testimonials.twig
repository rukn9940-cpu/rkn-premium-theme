{#
| Variable              | Type     | Description                                                                  |
|-----------------------|----------|------------------------------------------------------------------------------|
| component             | object   | Contains merchant settings for fields from twilight.json `component` section |
| component.items[].avatar | string | Customer avatar url                                                           |
| component.items[].name   | string | Customer name                                                                 |
| component.items[].stars  | int    | 1-5                                                                            |
| component.items[].text   | string | Review text                                                                    |
| position              | int      | Sorting number start from zero                                               |
#}
<section class="s-block rkn-testimonials-block container">
    <div class="rkn-sechead rkn-sechead--center">
        <h2 class="rkn-sectitle rkn-sectitle--center">{{ trans('blocks.home.testimonials') }}</h2>
    </div>

    <salla-slider id="rkn-testimonials-{{ position }}" type="testimonials" centered slides-per-view="1" controls-outer auto-play class="rkn-testimonials-slider">
        <div slot="items">
            {% for index, item in component.items %}
                <div class="swiper-slide rkn-review-slide">
                    <article class="rkn-review-card">
                        <span class="rkn-review-card__quote">&rdquo;</span>
                        <p class="rkn-review-card__text">{{ item.text }}</p>
                        <footer class="rkn-review-card__footer">
                            <img class="rkn-review-card__avatar" src="{{ item.avatar }}" loading="lazy" width="48" height="48" alt="{{ item.name|trim ? item.name : 'testimonial-' ~ index }}">
                            <div>
                                <b class="rkn-review-card__name">{{ item.name }}</b>
                                <salla-rating-stars size="small" value="{{ item.stars }}"></salla-rating-stars>
                            </div>
                        </footer>
                    </article>
                </div>
            {% endfor %}
        </div>
    </salla-slider>
</section>
