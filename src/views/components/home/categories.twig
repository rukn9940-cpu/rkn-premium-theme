{#
    Categories (Theme Component: home.categories)
    ===============================================
    Modern hover-animated cards linking to real store categories chosen by
    the merchant (Categories entity picker — see twilight.json).

    | component.title                | string      | optional heading      |
    | component.subtitle             | string      | optional sub heading  |
    | component.categories[].name    | string      |                        |
    | component.categories[].url     | string      |                        |
    | component.categories[].image   | string|null |                        |
#}
{% if component.categories is not empty %}
    <section class="section categories" aria-label="{{ component.title|default(trans('home.categories.default_title')) }}">
        <div class="container">
            <div class="section__head" data-reveal>
                <div class="section__heading">
                    <h2 class="section__title">{{ component.title|default(trans('home.categories.default_title')) }}</h2>
                    {% if component.subtitle %}
                        <p class="section__subtitle">{{ component.subtitle }}</p>
                    {% endif %}
                </div>
            </div>

            <div class="categories__grid">
                {% for category in component.categories %}
                    <a href="{{ category.url }}" class="category-card" data-reveal>
                        <span class="category-card__media">
                            {% if category.image %}
                                <img
                                    src="{{ category.image }}"
                                    alt="{{ category.name }}"
                                    loading="lazy"
                                    width="360"
                                    height="360"
                                >
                            {% else %}
                                <span class="category-card__placeholder" aria-hidden="true">
                                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                                        <path d="M4 7l8-4 8 4v10l-8 4-8-4V7Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                                        <path d="M4 7l8 4 8-4M12 11v10" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            {% endif %}
                        </span>
                        <span class="category-card__name">{{ category.name }}</span>
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>
{% endif %}
