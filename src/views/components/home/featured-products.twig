{#
    RKN Featured products — modern electronics product grid
#}
{% if component.products is not empty %}
    {% include 'partials.home.product-shelf' with {
        title: component.title|default(trans('home.featured_products.default_title')),
        subtitle: component.subtitle|default(null),
        eyebrow: trans('home.featured_products.eyebrow'),
        products: component.products,
        limit: component.products|length
    } %}
{% endif %}
