{#
    RKN Hero — full-width edge-to-edge slider (electronics storefront)
#}
{% if component.slides is not empty %}
    <section class="rkn-hero" aria-label="{{ trans('home.hero.aria_label') }}">
        <div class="carousel rkn-hero__carousel" data-carousel {% if component.slides|length > 1 %}data-autoplay="6000"{% endif %}>
            <div class="carousel__viewport">
                <ul class="carousel__track rkn-hero__track">
                    {% for slide in component.slides %}
                        <li class="carousel__slide rkn-hero__slide">
                            {% set tag = slide.cta_url ? 'a' : 'div' %}
                            <{{ tag }}{% if slide.cta_url %} href="{{ slide.cta_url }}" class="rkn-hero__link"{% else %} class="rkn-hero__frame"{% endif %}>
                                <picture class="rkn-hero__media">
                                    {% if slide.mobile_image %}
                                        <source media="(max-width: 767px)" srcset="{{ slide.mobile_image }}">
                                    {% endif %}
                                    <img
                                        src="{{ slide.image }}"
                                        alt="{{ slide.title|default('') }}"
                                        loading="{{ loop.first ? 'eager' : 'lazy' }}"
                                        fetchpriority="{{ loop.first ? 'high' : 'auto' }}"
                                        width="1920"
                                        height="640"
                                    >
                                </picture>
                                {% if slide.title or slide.subtitle or slide.cta_label %}
                                    <div class="rkn-hero__content">
                                        <div class="container">
                                            <div class="rkn-hero__copy">
                                                {% if slide.title %}
                                                    <h2 class="rkn-hero__title">{{ slide.title }}</h2>
                                                {% endif %}
                                                {% if slide.subtitle %}
                                                    <p class="rkn-hero__subtitle">{{ slide.subtitle }}</p>
                                                {% endif %}
                                                {% if slide.cta_label and not slide.cta_url %}
                                                    <span class="rkn-hero__cta">{{ slide.cta_label }}</span>
                                                {% elseif slide.cta_label %}
                                                    <span class="rkn-hero__cta">{{ slide.cta_label }}</span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                {% endif %}
                            </{{ tag }}>
                        </li>
                    {% endfor %}
                </ul>
            </div>

            {% if component.slides|length > 1 %}
                <button type="button" class="rkn-hero__nav rkn-hero__nav--prev" data-carousel-prev aria-label="{{ trans('carousel.previous') }}">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button type="button" class="rkn-hero__nav rkn-hero__nav--next" data-carousel-next aria-label="{{ trans('carousel.next') }}">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <div class="rkn-hero__dots carousel__dots" data-carousel-dots></div>
            {% endif %}
        </div>
    </section>
{% endif %}
