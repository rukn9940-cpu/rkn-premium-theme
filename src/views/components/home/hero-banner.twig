{#
    Hero Banner (Theme Component: home.hero-banner)
    ================================================
    Full-width, responsive slider with per-slide CTA buttons. Fields are
    declared in `twilight.json` › components › hero-banner and populated by
    the merchant from the Partners Portal theme editor — nothing here is
    hardcoded/fake.

    | component.slides[].image               | string | required, desktop art |
    | component.slides[].mobile_image        | string | optional, mobile art  |
    | component.slides[].title               | string |                        |
    | component.slides[].subtitle            | string |                        |
    | component.slides[].cta_label/cta_url   | string |                        |
    | component.slides[].secondary_cta_*     | string | optional second button |
#}
{% set hero_layout = component.layout|default('fullwidth') %}
{% if component.slides is not empty %}
    <section class="hero-banner" data-hero-layout="{{ hero_layout }}" aria-label="{{ trans('home.hero.aria_label') }}">
        <div class="carousel carousel--on-dark hero-banner__carousel" data-carousel {% if component.slides|length > 1 %}data-autoplay="6500"{% endif %}>
            <div class="carousel__viewport">
                <ul class="carousel__track hero-banner__track">
                    {% for slide in component.slides %}
                        <li class="carousel__slide hero-banner__slide">
                            <picture class="hero-banner__media">
                                {% if slide.mobile_image %}
                                    <source media="(max-width: 767px)" srcset="{{ slide.mobile_image }}">
                                {% endif %}
                                <img
                                    src="{{ slide.image }}"
                                    alt="{{ slide.title|default('') }}"
                                    loading="{{ loop.first ? 'eager' : 'lazy' }}"
                                    fetchpriority="{{ loop.first ? 'high' : 'auto' }}"
                                    width="1920"
                                    height="760"
                                >
                            </picture>
                            <div class="hero-banner__overlay"></div>

                            {% if slide.title or slide.subtitle or slide.cta_label or slide.secondary_cta_label %}
                                <div class="hero-banner__content container">
                                    <div class="hero-banner__text">
                                        {% if slide.title %}<h2 class="hero-banner__title">{{ slide.title }}</h2>{% endif %}
                                        {% if slide.subtitle %}<p class="hero-banner__subtitle">{{ slide.subtitle }}</p>{% endif %}

                                        {% if slide.cta_label or slide.secondary_cta_label %}
                                            <div class="hero-banner__actions">
                                                {% if slide.cta_label %}
                                                    <a href="{{ slide.cta_url|default('#') }}" class="btn btn--primary btn--lg">{{ slide.cta_label }}</a>
                                                {% endif %}
                                                {% if slide.secondary_cta_label %}
                                                    <a href="{{ slide.secondary_cta_url|default('#') }}" class="btn btn--ghost btn--lg">{{ slide.secondary_cta_label }}</a>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                            {% endif %}
                        </li>
                    {% endfor %}
                </ul>
            </div>

            {% if component.slides|length > 1 %}
                <button type="button" class="carousel__control carousel__control--prev" data-carousel-prev aria-label="{{ trans('carousel.previous') }}">
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <button type="button" class="carousel__control carousel__control--next" data-carousel-next aria-label="{{ trans('carousel.next') }}">
                    <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </button>
                <div class="carousel__dots hero-banner__dots" data-carousel-dots></div>
            {% endif %}
        </div>
    </section>
{% endif %}
