{#
    Promo Video (Theme Component: home.video)
    Click-to-load YouTube facade — RKN storefront styling.
#}
{% if component.youtube_url %}
    <section class="rkn-block rkn-video">
        <div class="container">
            {% if component.title %}
                {% include 'partials.home.section-head' with {
                    title: component.title,
                    subtitle: component.subtitle|default(null)
                } %}
            {% endif %}

            <div
                class="rkn-video__player"
                data-youtube-facade
                data-youtube-url="{{ component.youtube_url }}"
            >
                {% if component.poster %}
                    <img src="{{ component.poster }}" alt="" loading="lazy" width="1280" height="720" class="rkn-video__poster">
                {% endif %}
                <button type="button" class="rkn-video__play" aria-label="{{ trans('home.video.play') }}">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M8 5.5v13l11-6.5-11-6.5Z" fill="currentColor" />
                    </svg>
                </button>
            </div>
        </div>
    </section>
{% endif %}
