{#
    RKN Trust strip — store feature icons (Salla Theme Feature data)
#}
{% if items is not empty %}
    <section class="rkn-trust" aria-label="{{ trans('home.store_features.aria_label') }}">
        <div class="container">
            <ul class="rkn-trust__grid">
                {% for item in items %}
                    <li class="rkn-trust__item" data-reveal>
                        <span class="rkn-trust__icon" aria-hidden="true">
                            <i class="{{ item.icon }}"></i>
                        </span>
                        <div class="rkn-trust__body">
                            <h3 class="rkn-trust__title">{{ item.title }}</h3>
                            {% if item.text %}
                                <p class="rkn-trust__text">{{ item.text }}</p>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
    </section>
{% endif %}
