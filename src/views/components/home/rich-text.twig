{#
    Rich Text Block (Theme Component: home.rich-text)
    Merchant-authored copy block — RKN storefront styling.
#}
{% if component.content %}
    <section class="rkn-block rkn-rich-text{{ component.center_align ? ' rkn-rich-text--center' : '' }}">
        <div class="container rkn-rich-text__inner">
            {% if component.title %}
                {% include 'partials.home.section-head' with {
                    title: component.title
                } %}
            {% endif %}
            <div class="rkn-rich-text__content">{{ component.content }}</div>
        </div>
    </section>
{% endif %}
