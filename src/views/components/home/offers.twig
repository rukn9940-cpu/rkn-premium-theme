{#
    RKN Flash offer — split promo banner + product row
#}
{% if component.image %}
    <section class="rkn-block rkn-deal" aria-label="{{ component.title|default(trans('home.offers.default_title')) }}">
        <div class="container">
            <div class="rkn-deal__layout">
                <div class="rkn-deal__banner" data-reveal>
                    <picture class="rkn-deal__media">
                        <img src="{{ component.image }}" alt="{{ component.title|default('') }}" loading="lazy" width="640" height="720">
                    </picture>
                    <div class="rkn-deal__overlay" aria-hidden="true"></div>
                    <div class="rkn-deal__content">
                        <span class="rkn-deal__badge">{{ trans('home.offers.flash_badge') }}</span>
                        <h2 class="rkn-deal__title">{{ component.title|default(trans('home.offers.default_title')) }}</h2>
                        {% if component.subtitle %}
                            <p class="rkn-deal__subtitle">{{ component.subtitle }}</p>
                        {% endif %}
                        {% if component.end_date %}
                            <div class="rkn-deal__countdown">
                                <span class="rkn-deal__countdown-label">{{ trans('home.offers.countdown_ends_in') }}</span>
                                <salla-count-down date="{{ component.end_date }}" color="light" size="sm" boxed="true"></salla-count-down>
                            </div>
                        {% endif %}
                        {% if component.cta_label %}
                            <a href="{{ component.cta_url|default('#') }}" class="rkn-deal__cta">{{ component.cta_label }}</a>
                        {% endif %}
                    </div>
                </div>

                {% if component.products is not empty %}
                    <div class="rkn-deal__products">
                        {% for product in component.products %}
                            {% include 'partials.product.card' with { product: product, reveal: true, variant: 'premium' } %}
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </section>
{% endif %}
