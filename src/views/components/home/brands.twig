{#
    RKN Brand carousel — horizontal logo strip
#}
{% if component.brands is not empty %}
    <section class="rkn-block rkn-brands" aria-label="{{ component.title|default(trans('home.brands.default_title')) }}">
        <div class="container">
            {% include 'partials.home.section-head' with {
                title: component.title|default(trans('home.brands.default_title')),
                subtitle: null,
                eyebrow: trans('home.brands.eyebrow')|default(null),
                link_url: page('brands'),
                link_label: trans('common.view_all')
            } %}

            <div class="carousel rkn-brands__carousel" data-carousel>
                <div class="carousel__viewport">
                    <ul class="carousel__track rkn-brands__track">
                        {% for brand in component.brands %}
                            <li class="carousel__slide rkn-brands__slide">
                                <a href="{{ brand.url }}" class="rkn-brand-card" aria-label="{{ brand.name }}" data-reveal>
                                    <img src="{{ brand.logo }}" alt="{{ brand.name }}" loading="lazy" width="120" height="64">
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>
                {% if component.brands|length > 4 %}
                    <button type="button" class="rkn-brands__nav rkn-brands__nav--prev" data-carousel-prev aria-label="{{ trans('carousel.previous') }}">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <button type="button" class="rkn-brands__nav rkn-brands__nav--next" data-carousel-next aria-label="{{ trans('carousel.next') }}">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                {% endif %}
            </div>
        </div>
    </section>
{% endif %}
