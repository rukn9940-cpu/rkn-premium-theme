{#
    Brands Slider (Theme Component: home.brands)
    ==============================================
    Horizontal, swipeable slider of the store's real brand logos
    (Brands entity picker — see twilight.json; matches Salla's own
    documented "Brands" component contract: component.brands[].{name,url,logo}).
#}
{% if component.brands is not empty %}
    <section class="section section--alt brands" aria-label="{{ component.title|default(trans('home.brands.default_title')) }}">
        <div class="container">
            <div class="section__head" data-reveal>
                <div class="section__heading">
                    <h2 class="section__title">{{ component.title|default(trans('home.brands.default_title')) }}</h2>
                </div>
                <a href="{{ page('brands') }}" class="section__link">
                    {{ trans('common.view_all') }}
                    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                        <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
            </div>

            <div class="carousel brands__carousel" data-carousel>
                <div class="carousel__viewport">
                    <ul class="carousel__track brands__track">
                        {% for brand in component.brands %}
                            <li class="carousel__slide brands__slide">
                                <a href="{{ brand.url }}" class="brand-card" aria-label="{{ brand.name }}" data-reveal>
                                    <img src="{{ brand.logo }}" alt="{{ brand.name }}" loading="lazy" width="140" height="80">
                                </a>
                            </li>
                        {% endfor %}
                    </ul>
                </div>

                {% if component.brands|length > 5 %}
                    <button type="button" class="carousel__control carousel__control--prev" data-carousel-prev aria-label="{{ trans('carousel.previous') }}">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                    <button type="button" class="carousel__control carousel__control--next" data-carousel-next aria-label="{{ trans('carousel.next') }}">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                            <path d="M7.5 5L12.5 10L7.5 15" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </button>
                {% endif %}
            </div>
        </div>
    </section>
{% endif %}
