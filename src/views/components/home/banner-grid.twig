{#
    RKN Promotional banner grid
#}
{% if component.banners is not empty %}
    <section class="rkn-block rkn-promos" aria-label="{{ component.title|default(trans('home.banner_grid.default_title')) }}">
        <div class="container">
            {% if component.title %}
                {% include 'partials.home.section-head' with {
                    title: component.title,
                    subtitle: null,
                    eyebrow: trans('home.banner_grid.eyebrow')|default(null)
                } %}
            {% endif %}

            <div class="rkn-promos__grid">
                {% for banner in component.banners %}
                    {% set tag = banner.url ? 'a' : 'div' %}
                    <{{ tag }}
                        class="rkn-promo rkn-promo--{{ banner.size|default('full') }}"
                        {% if banner.url %}href="{{ banner.url }}"{% endif %}
                        data-reveal
                    >
                        <picture class="rkn-promo__media">
                            {% if banner.mobile_image %}
                                <source media="(max-width: 767px)" srcset="{{ banner.mobile_image }}">
                            {% endif %}
                            <img
                                src="{{ banner.image }}"
                                alt="{{ banner.title|default('') }}"
                                loading="lazy"
                                width="800"
                                height="420"
                            >
                        </picture>
                        {% if banner.title or banner.subtitle or banner.cta_label %}
                            <div class="rkn-promo__content">
                                {% if banner.title %}<h3 class="rkn-promo__title">{{ banner.title }}</h3>{% endif %}
                                {% if banner.subtitle %}<p class="rkn-promo__subtitle">{{ banner.subtitle }}</p>{% endif %}
                                {% if banner.cta_label %}<span class="rkn-promo__cta">{{ banner.cta_label }}</span>{% endif %}
                            </div>
                        {% endif %}
                    </{{ tag }}>
                {% endfor %}
            </div>
        </div>
    </section>
{% endif %}
