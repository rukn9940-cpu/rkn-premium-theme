{#
    RKN Storefront Footer
    =======================
    Modern electronics-store footer: brand column, link columns, contact,
    app badges, payment methods, and copyright bar.
#}
{% set footer_layout = theme.settings.get('footer_layout', 'classic') %}
<footer class="footer footer--storefront" data-footer-layout="{{ footer_layout }}">
    <div class="footer__top">
        <div class="container footer__top-inner">
            <div class="footer__brand">
                <a href="{{ store.url }}" class="footer__logo" aria-label="{{ store.name }}">
                    {% if store.logo %}
                        <img src="{{ store.logo }}" alt="{{ store.name }}" width="140" height="40">
                    {% else %}
                        <span class="footer__logo-text">{{ store.name }}</span>
                    {% endif %}
                </a>
                {% if store.description %}
                    <p class="footer__description">{{ store.description|striptags }}</p>
                {% endif %}
                <div class="footer__social-block">
                    <h3 class="footer__col-title">{{ trans('footer.follow_us') }}</h3>
                    <salla-social class="footer__social"></salla-social>
                </div>
            </div>

            <div class="footer__col">
                <h3 class="footer__col-title">{{ trans('footer.quick_links') }}</h3>
                <salla-menu source="footer" class="footer__menu"></salla-menu>
            </div>

            <div class="footer__col">
                <h3 class="footer__col-title">{{ trans('footer.contact_us') }}</h3>
                <salla-contacts class="footer__contacts"></salla-contacts>
            </div>

            <div class="footer__col footer__col--apps">
                <h3 class="footer__col-title">{{ trans('footer.get_the_app') }}</h3>
                <salla-apps-icons class="footer__apps"></salla-apps-icons>
            </div>
        </div>
    </div>

    <div class="footer__bottom">
        <div class="container footer__bottom-inner">
            <p class="footer__copyright">
                {{ trans('footer.rights', {'year': 'now'|date('Y'), 'store': store.name}) }}
            </p>
            <div class="footer__payments-block">
                <span class="footer__payments-label">{{ trans('footer.payment_methods') }}</span>
                <salla-payments class="footer__payments"></salla-payments>
            </div>
            {% hook 'footer:copyright' %}
        </div>
    </div>
</footer>
